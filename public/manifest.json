{
    "name": "Atlas Obsura - New Tab",
    "description": "Discover a hidden wonder with each new tab.",
    "homepage_url": "https://atlasobscura.com",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "manifest_version": 3,
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    },
    "icons": {
        "128": "atlas-obscura-logo.png",
        "16": "atlas-obscura-logo.png",
        "48": "atlas-obscura-logo.png"
    },
    "permissions": ["storage"],
    "host_permissions": [
        "https://atlasobscura.com/*",
        "https://www.atlasobscura.com/*",
        "http://www.atlasobscura.com/*"
    ],
    "update_url": "https://clients2.google.com/service/update2/crx",
    "version": "1.0.0",
    "web_accessible_resources": [
        {
            "resources": ["font/*.woff2", "js/*.json"],
            "matches": ["<all_urls>"]
        }
    ]
}
